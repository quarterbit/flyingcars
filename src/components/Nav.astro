---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<nav class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-slate-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <a href={base} class="flex items-center gap-2 font-bold text-lg text-charcoal hover:text-sky-600 transition-colors">
        <span class="text-2xl">⚡</span>
        <span class="hidden sm:inline">flyingcars.blog</span>
      </a>

      <div class="hidden md:flex items-center gap-8">
        <a href={base} class:list={["text-sm font-medium transition", currentPath === base ? "text-sky-600" : "text-slate-600 hover:text-sky-600"]}>Start</a>
        <a href={`${base}/#beitraege`} class="text-sm font-medium text-slate-600 hover:text-sky-600 transition">Beiträge</a>
        <a href={`${base}downloads/`} class:list={["text-sm font-medium transition", currentPath.includes("downloads") ? "text-sky-600" : "text-slate-600 hover:text-sky-600"]}>Downloads</a>
        <a href={`${base}impressum/`} class:list={["text-sm font-medium transition", currentPath.includes("impressum") ? "text-sky-600" : "text-slate-600 hover:text-sky-600"]}>Impressum</a>
      </div>

      <button id="mobile-menu-btn" class="md:hidden p-2 text-slate-600 hover:text-slate-900 transition" aria-label="Menü öffnen">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-slate-100">
      <div class="flex flex-col gap-3 pt-4">
        <a href={base} class="text-sm font-medium text-slate-600 hover:text-sky-600 transition px-2 py-1">Start</a>
        <a href={`${base}/#beitraege`} class="text-sm font-medium text-slate-600 hover:text-sky-600 transition px-2 py-1">Beiträge</a>
        <a href={`${base}downloads/`} class="text-sm font-medium text-slate-600 hover:text-sky-600 transition px-2 py-1">Downloads</a>
        <a href={`${base}impressum/`} class="text-sm font-medium text-slate-600 hover:text-sky-600 transition px-2 py-1">Impressum</a>
      </div>
    </div>
  </div>
</nav>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
