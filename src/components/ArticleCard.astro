---
interface Props {
  title: string;
  date: Date;
  description: string;
  image?: string;
  slug: string;
  tags?: string[];
}

const { title, date, description, image, slug, tags = [] } = Astro.props;
const base = import.meta.env.BASE_URL;
const formattedDate = date.toLocaleDateString('de-DE', {
  day: 'numeric', month: 'long', year: 'numeric'
});
---

<a href={`${base}blog/${slug}/`} class="group block h-full">
  <article class="rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 bg-white border border-slate-200 h-full flex flex-col">
    {image && (
      <div class="overflow-hidden h-48">
        <img
          src={`${base}img/${image}`}
          alt={title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      </div>
    )}
    <div class="p-5 flex flex-col flex-1">
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mb-3">
          {tags.slice(0, 3).map(tag => (
            <span class="text-xs px-2 py-0.5 rounded-full bg-sky-50 text-sky-700 font-medium">{tag}</span>
          ))}
        </div>
      )}
      <h3 class="text-lg font-bold text-slate-900 group-hover:text-sky-600 transition-colors mb-2 line-clamp-2">{title}</h3>
      <p class="text-slate-600 text-sm mb-4 line-clamp-3 flex-1">{description}</p>
      <time class="text-xs text-slate-400 font-medium uppercase tracking-wider">{formattedDate}</time>
    </div>
  </article>
</a>
